# ── Resend (waitlist emails) ──────────────────────────────────────────────────
# Get your API key at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address for confirmation emails.
# Must be a verified domain in Resend (e.g. your sending domain at resend.com).
RESEND_FROM_EMAIL=WYN <noreply@wyn.africa>

# Internal team email to receive new waitlist notifications
TEAM_EMAIL=contact@wyn.africa

# ── Waitlist counter ──────────────────────────────────────────────────────────
# Update this number manually in Vercel env vars to reflect the real count
# until a database is connected.
WAITLIST_COUNT=0

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://wyn.africa

# ── Analytics (client-side, exposed via VITE_ prefix) ────────────────────────
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA4_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel ID
VITE_META_PIXEL_ID=XXXXXXXXXXXXXXXXXX

# TikTok Pixel ID
VITE_TIKTOK_PIXEL_ID=XXXXXXXXXXXXXXXXXX

# Plausible Analytics domain (e.g. wyn.africa)
VITE_PLAUSIBLE_DOMAIN=wyn.africa
